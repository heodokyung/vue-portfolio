{
  "name": "vue-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 8000 --strictPort --clearScreen false",
    "build": "vue-tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 8000 --strictPort",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint . --ext .vue,.ts --max-warnings=0",
    "format": "prettier --write ."
  },
  "dependencies": {
    "vue": "3.5.13",
    "vue-router": "4.5.0"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "1.10.5",
    "@tsconfig/node22": "22.0.0",
    "@vitejs/plugin-vue": "5.2.1",
    "@vue/eslint-config-prettier": "10.1.0",
    "@vue/eslint-config-typescript": "14.3.0",
    "@vue/tsconfig": "0.7.0",
    "eslint": "9.19.0",
    "eslint-plugin-vue": "9.32.0",
    "prettier": "3.4.2",
    "sass": "1.83.4",
    "typescript": "5.7.3",
    "vite": "6.1.0",
    "vue-tsc": "2.2.0"
  }
}
